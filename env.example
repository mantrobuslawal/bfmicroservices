# bfstore local development environment
#
# Copy this file to `.env` for local development:
#
#   cp .env.example .env
#
# Do not commit `.env`.
#
# These values are intended for local development only.

# -------------------------------------------------------------------
# Project
# -------------------------------------------------------------------

PROJECT_NAME=bfstore
ENVIRONMENT=local
LOG_LEVEL=debug

# -------------------------------------------------------------------
# MySQL
# -------------------------------------------------------------------

MYSQL_ROOT_PASSWORD=bfstore_root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

CATALOG_DB_NAME=bfstore_catalog
CATALOG_DB_USER=bfstore_catalog_user
CATALOG_DB_PASSWORD=bfstore_catalog_password

BASKET_DB_NAME=bfstore_basket
BASKET_DB_USER=bfstore_basket_user
BASKET_DB_PASSWORD=bfstore_basket_password

INVENTORY_DB_NAME=bfstore_inventory
INVENTORY_DB_USER=bfstore_inventory_user
INVENTORY_DB_PASSWORD=bfstore_inventory_password

ORDER_DB_NAME=bfstore_order
ORDER_DB_USER=bfstore_order_user
ORDER_DB_PASSWORD=bfstore_order_password

PAYMENT_DB_NAME=bfstore_payment
PAYMENT_DB_USER=bfstore_payment_user
PAYMENT_DB_PASSWORD=bfstore_payment_password

SHIPPING_DB_NAME=bfstore_shipping
SHIPPING_DB_USER=bfstore_shipping_user
SHIPPING_DB_PASSWORD=bfstore_shipping_password

NOTIFICATION_DB_NAME=bfstore_notification
NOTIFICATION_DB_USER=bfstore_notification_user
NOTIFICATION_DB_PASSWORD=bfstore_notification_password

# -------------------------------------------------------------------
# Kafka
# -------------------------------------------------------------------

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

KAFKA_TOPIC_ORDER_EVENTS=bfstore.order.orders.v1
KAFKA_TOPIC_INVENTORY_EVENTS=bfstore.inventory.stock.v1
KAFKA_TOPIC_PAYMENT_EVENTS=bfstore.payment.payments.v1
KAFKA_TOPIC_SHIPPING_EVENTS=bfstore.shipping.shipments.v1
KAFKA_TOPIC_NOTIFICATION_EVENTS=bfstore.notification.notifications.v1
KAFKA_TOPIC_CATALOG_EVENTS=bfstore.catalog.products.v1

# -------------------------------------------------------------------
# Service ports
# -------------------------------------------------------------------

API_GATEWAY_HTTP_PORT=8080

CATALOG_SERVICE_GRPC_PORT=50051
BASKET_SERVICE_GRPC_PORT=50052
INVENTORY_SERVICE_GRPC_PORT=50053
ORDER_SERVICE_GRPC_PORT=50054
PAYMENT_SERVICE_GRPC_PORT=50055
SHIPPING_SERVICE_GRPC_PORT=50056
NOTIFICATION_SERVICE_GRPC_PORT=50057

# -------------------------------------------------------------------
# Observability
# -------------------------------------------------------------------
ENVIRONMENT=local
SERVICE_VERSION=local
TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_INSECURE=true
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
TRACES_ENABLED=true
METRICS_ENABLED=true
METRIC_EXPORT_INTERVAL=30s

